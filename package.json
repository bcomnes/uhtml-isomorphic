{
  "name": "uhtml-isomorphic",
  "description": "Isomorphic exports of uhtml",
  "version": "2.1.0",
  "author": "Bret Comnes <bcomnes@gmail.com> (https://bret.io)",
  "bugs": {
    "url": "https://github.com/bcomnes/uhtml-isomorphic/issues"
  },
  "dependencies": {
    "@types/node": "^22.10.2",
    "uhtml": "^4.1.8",
    "uhtml-ssr": "^0.9.1"
  },
  "devDependencies": {
    "@voxpelli/tsconfig": "^15.1.0",
    "auto-changelog": "^2.0.0",
    "gh-release": "^7.0.0",
    "c8": "^10.0.0",
    "jsdom": "^26.0.0",
    "neostandard": "^0.12.0",
    "npm-run-all2": "^7.0.1",
    "typescript": "~5.7.2"
  },
  "homepage": "https://github.com/bcomnes/uhtml-isomorphic",
  "keywords": [],
  "license": "MIT",
  "main": "./node.cjs",
  "browser": {
    ".": "./browser.cjs",
    "./async.js": "./async.browser.cjs"
  },
  "module": "./browser.mjs",
  "exports": {
    ".": {
      "browser": "./browser.mjs",
      "import": "./node.mjs",
      "require": "./node.cjs"
    },
    "./async": {
      "browser": "./async.browser.mjs",
      "import": "./async.mjs",
      "require": "./async.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bcomnes/uhtml-isomorphic.git"
  },
  "scripts": {
    "prepublishOnly": "npm run build && git push --follow-tags && gh-release -y",
    "postpublish": "npm run clean",
    "test": "run-s test:*",
    "test:lint": "eslint",
    "test-skip:node": "c8 node --test",
    "test:tsc": "tsc",
    "version": "run-s version:*",
    "version:changelog": "auto-changelog -p --template keepachangelog auto-changelog --breaking-pattern 'BREAKING CHANGE:'",
    "version:git": "git add CHANGELOG.md",
    "clean": "run-p clean:*",
    "clean:declarations-top": "rm -rf $(find . -maxdepth 1 -type f \\( -name '*.d.ts*' -o -name '*.cts*' \\))",
    "clean:declarations-lib": "rm -rf $(find lib -type f -name '*.d.ts*' ! -name '*-types.d.ts')",
    "build": "npm run clean && run-p build:*",
    "build:declaration": "tsc -p declaration.tsconfig.json"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/bcomnes"
  },
  "c8": {
    "reporter": [
      "lcov",
      "text"
    ]
  }
}
